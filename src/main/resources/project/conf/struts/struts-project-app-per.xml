<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN" "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
    <package extends="default" name="per" namespace="/per" strict-method-invocation="false">
        <default-interceptor-ref name="ZebraDefaultStack"/>
        <!--Per0202 - Person Profile-->
        <action class="project.app.per.per0202.Per0202Action" method="{1}" name="0202/*">
            <result name="list" type="debugDispatcherResult">/project/app/per/per0202/Per0202List.jsp</result>
            <result name="personDetail" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonDetailFrameContainer.jsp</result>
            <result name="personal" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonDetailPersonalFrame.jsp</result>
            <result name="contact" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonDetailContactFrame.jsp</result>
            <result name="document" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonDetailDocumentFrame.jsp</result>
            <result name="additionalService" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonDetailAdditionalServiceFrame.jsp</result>
            <result name="communication" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonDetailCommunicationFrame.jsp</result>
            <result name="nextActions" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonDetailNextActionsFrame.jsp</result>
            <result name="ecmsEbo" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonDetailEcmsEboFrame.jsp</result>
            <result name="portal" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonDetailPortalFrame.jsp</result>
        </action>
    </package>
</struts>
