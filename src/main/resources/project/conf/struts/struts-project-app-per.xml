<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN" "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
    <package extends="default" name="per" namespace="/per" strict-method-invocation="false">
        <default-interceptor-ref name="ZebraDefaultStack"/>
        <!--Per0202 - Person Profile-->
        <action class="project.app.per.per0202.Per0202Action" method="{1}" name="0202/*">
            <result name="list" type="debugDispatcherResult">/project/app/per/per0202/Per0202List.jsp</result>
            <result name="detail" type="debugDispatcherResult">/project/app/per/per0202/Per0202DetailPop.jsp</result>
            <result name="insert" type="debugDispatcherResult">/project/app/per/per0202/Per0202InsertPop.jsp</result>
            <result name="update" type="debugDispatcherResult">/project/app/per/per0202/Per0202UpdatePop.jsp</result>
        </action>
    </package>
</struts>
