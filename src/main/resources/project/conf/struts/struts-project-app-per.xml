<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN" "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
    <package extends="default" name="per" namespace="/per" strict-method-invocation="false">
        <default-interceptor-ref name="ZebraDefaultStack"/>
        <!--Per0202 - Person Profile-->
        <action class="project.app.per.per0202.Per0202Action" method="{1}" name="0202/*">
            <result name="list" type="debugDispatcherResult">/project/app/per/per0202/Per0202List.jsp</result>
            <result name="personDetailFrameContainer" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonDetailFrameContainer.jsp</result>
            <result name="personal" type="debugDispatcherResult">/project/app/per/per0202/Per0202PersonalFrame.jsp</result>
            <result name="contact" type="debugDispatcherResult">/project/app/per/per0202/Per0202ContactFrame.jsp</result>
            <result name="additionalService" type="debugDispatcherResult">/project/app/per/per0202/Per0202AdditionalServiceFrame.jsp</result>
            <result name="communication" type="debugDispatcherResult">/project/app/per/per0202/Per0202CommunicationFrame.jsp</result>
            <result name="nextActions" type="debugDispatcherResult">/project/app/per/per0202/Per0202NextActionsFrame.jsp</result>
        </action>
        <!--Per0204 - Document-->
        <action class="project.app.per.per0204.Per0204Action" method="{1}" name="0204/*">
            <result name="list" type="debugDispatcherResult">/project/app/per/per0204/Per0204List.jsp</result>
            <result name="documentFrameContainer" type="debugDispatcherResult">/project/app/per/per0204/Per0204DocumentFrameContainer.jsp</result>
            <result name="outstanding" type="debugDispatcherResult">/project/app/per/per0204/Per0204OutstandingDocumentFrame.jsp</result>
            <result name="received" type="debugDispatcherResult">/project/app/per/per0204/Per0204ReceivedDocumentFrame.jsp</result>
        </action>
    </package>
</struts>
