<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:aop="http://www.springframework.org/schema/aop"
	xmlns:context="http://www.springframework.org/schema/context"
	xmlns:tx="http://www.springframework.org/schema/tx"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-4.3.xsd
		http://www.springframework.org/schema/aop http://www.springframework.org/schema/aop/spring-aop-4.3.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-4.3.xsd
		http://www.springframework.org/schema/tx http://www.springframework.org/schema/tx/spring-tx-4.3.xsd">

	<!-- enabling @AspectJ -->
	<aop:aspectj-autoproxy/>

	<!-- cross-cutting concern -->
	<bean id="loggingAdvice" class="${name.package.framework}.aop.LoggingAdvice" />
	<bean id="exceptionLoggingAdvice" class="${name.package.framework}.aop.ExceptionLoggingAdvice" />

	<!-- configuring AOP using AOP namespace & XML schema -->
	<aop:config>
		<aop:pointcut id="loggingPointcut" expression="execution(* ${name.package.project}..*Biz.*(..)) or execution(* ${name.package.project}..*Dao.*(..)) or execution(* ${name.package.framework}..*Biz.*(..)) or execution(* ${name.package.framework}..*Dao.*(..))" />
		<aop:aspect id="loggingAspect" ref="loggingAdvice">
			<aop:around pointcut-ref="loggingPointcut" method="executeLogging" />
		</aop:aspect>
	</aop:config>
	<aop:config>
		<aop:pointcut id="exceptionLoggingPointcut" expression="execution(* ${name.package.project}..*Biz.*(..)) or execution(* ${name.package.project}..*Dao.*(..)) or execution(* ${name.package.framework}..*Biz.*(..)) or execution(* ${name.package.framework}..*Dao.*(..))" />
		<aop:aspect id="exceptionLoggingAspect" ref="exceptionLoggingAdvice">
			<aop:after-throwing throwing="exception" pointcut-ref="exceptionLoggingPointcut" method="executeLogging"/>
		</aop:aspect>
	</aop:config>

	<!-- Transaction -->
	<aop:config>
		<aop:pointcut id="txPointcut" expression="execution(* ${name.package.project}..*Biz.*(..)) or execution(* ${name.package.project}..*Dao.*(..)) or execution(* ${name.package.framework}..*Biz.*(..)) or execution(* ${name.package.framework}..*Dao.*(..))" />
		<!-- Additional advisor can be added -->
		<!-- Database Transaction Configuration(must be set alternatively MyBatis or Hibernate) -->
<!-- 		<aop:advisor advice-ref="txAdviceForJdbc" pointcut-ref="txPointcut"/> -->
		<aop:advisor advice-ref="txAdviceForHibernate" pointcut-ref="txPointcut"/>
		<!-- For Multiple Datasource -->
		<aop:advisor advice-ref="txAdviceForHibernate_alpaca" pointcut-ref="txPointcut"/>
		<aop:advisor advice-ref="txAdviceForHibernate_perciTest" pointcut-ref="txPointcut"/>
		<aop:advisor advice-ref="txAdviceForHibernate_perciProd" pointcut-ref="txPointcut"/>
	</aop:config>
	<!-- Transaction Advice -->
	<tx:advice id="txAdviceForJdbc" transaction-manager="txManagerForJdbc">
		<tx:attributes>
			<tx:method name="get*" read-only="true"/>
			<tx:method name="select*" read-only="true"/>
			<tx:method name="save*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="exe*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="insert*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="update*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="delete*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
		</tx:attributes>
	</tx:advice>
	<tx:advice id="txAdviceForHibernate" transaction-manager="txManagerForHibernate">
		<tx:attributes>
			<tx:method name="get*" read-only="true"/>
			<tx:method name="select*" read-only="true"/>
			<tx:method name="save*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="exe*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="insert*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="update*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="delete*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
		</tx:attributes>
	</tx:advice>
	<!-- Transaction based on Annotation (both are OK) -->
	<tx:annotation-driven transaction-manager="txManagerForJdbc"/>
<!--	<bean class="org.springframework.orm.jpa.support.PersistenceAnnotationBeanPostProcessor"/>-->


	<!-- Multiple Datasource Transaction -->
	<!-- Transaction Advice -->
	<tx:advice id="txAdviceForHibernate_alpaca" transaction-manager="txManagerForHibernate_alpaca">
		<tx:attributes>
			<tx:method name="get*" read-only="true"/>
			<tx:method name="select*" read-only="true"/>
			<tx:method name="save*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="exe*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="insert*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="update*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="delete*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
		</tx:attributes>
	</tx:advice>
	<tx:advice id="txAdviceForHibernate_perciTest" transaction-manager="txManagerForHibernate_perciTest">
		<tx:attributes>
			<tx:method name="get*" read-only="true"/>
			<tx:method name="select*" read-only="true"/>
			<tx:method name="save*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="exe*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="insert*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="update*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="delete*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
		</tx:attributes>
	</tx:advice>
	<tx:advice id="txAdviceForHibernate_perciProd" transaction-manager="txManagerForHibernate_perciProd">
		<tx:attributes>
			<tx:method name="get*" read-only="true"/>
			<tx:method name="select*" read-only="true"/>
			<tx:method name="save*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="exe*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="insert*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="update*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
			<tx:method name="delete*" propagation="REQUIRED" timeout="600" rollback-for="Exception"/>
		</tx:attributes>
	</tx:advice>


<!--
	1. tx:method attribute
		1.1 name : [эХДьИШ] эК╕ыЮЬьЮньЕШьЭ┤ ьаБьЪйыРа ыйФьДЬыУЬ ьЭ┤ыжД. '*'ьЭД ьВмьЪйэХЬ ьДдьаХъ░АыКе.
		1.2 propagation : [ьДаэГЭ/REQUIRED] эК╕ыЮЬьЮньЕШ ьаДэММ ъ╖Ьь╣Щ.
		1.3 isolation : [ьДаэГЭ/DEFAULT] эК╕ыЮЬьЮньЕШ ъ▓йыжм ыаИы▓и.
		1.4 read-only : [ьДаэГЭ/false] ьЭ╜ъ╕░ьаДьЪй ьЧмы╢А.
		1.5 no-rollback-for : [ьДаэГЭ/ъ╕░ы│╕ъ░Т ьЧЖьЭМ] эК╕ыЮЬьЮньЕШьЭД ыбды░▒эХШьзА ьХКьЭД ьШИьЩ╕ эГАьЮЕ.
		1.6 rollback-for : [ьДаэГЭ/ъ╕░ы│╕ъ░Т ьЧЖьЭМ] эК╕ыЮЬьЮньЕШьЭД ыбды░▒ эХа ьШИьЩ╕ эГАьЮЕ.
		1.7 timeout : [ьДаэГЭ/-1] эК╕ыЮЬьЮньЕШьЭШ эГАьЮДьХДьЫГ ьЛЬъ░Д. ь┤И ыЛиьЬД ьДдьаХ.

	2. PROPAGATION (ьЭ╝ы░ШьаБьЬ╝ыбЬ ы│ДыПД ь▓Шыжмъ░А эХДьЪФэХШьзА ьХКьЭД ъ▓╜ьЪ░ REQUIRED ьВмьЪй)
		2.1 REQUIRED : ьЭ┤ып╕ TransactionьЭ┤ ьб┤ьЮмэХа ъ▓╜ьЪ░ эХ┤ыЛ╣ Transaction ьВмьЪй / TransactionьЭ┤ ьЧЖьЭД ъ▓╜ьЪ░ ьГИыбЬьЪ┤ Transaction ьГЭьД▒
		2.2 MANDATORY : ьЭ┤ып╕ TransactionьЭ┤ ьб┤ьЮмэХа ъ▓╜ьЪ░ эХ┤ыЛ╣ Transaction ьВмьЪй / TransactionьЭ┤ ьЧЖьЭД ъ▓╜ьЪ░ Exception ы░ЬьГЭ
		2.3 REQUIRES_NEW : ьЭ┤ып╕ TransactionьЭ┤ ьб┤ьЮмэХа ъ▓╜ьЪ░ эХ┤ыЛ╣ TransactionьЭД ы│┤ыеШьЛЬэВдъ│а ьГИ Transaction ьГЭьД▒ / TransactionьЭ┤ ьЧЖьЭД ъ▓╜ьЪ░ ьГИыбЬьЪ┤ Transaction ьГЭьД▒
		2.4 SUPPORTS : ьЭ┤ып╕ TransactionьЭ┤ ьб┤ьЮмэХа ъ▓╜ьЪ░ эХ┤ыЛ╣ Transaction ьВмьЪй / TransactionьЭ┤ ьЧЖьЭД ъ▓╜ьЪ░ ъ╖╕ыГе ьЛдэЦЙ
		2.5 NOT_SUPPORTED : ьЭ┤ып╕ TransactionьЭ┤ ьб┤ьЮмэХа ъ▓╜ьЪ░ эХ┤ыЛ╣ TransactionьЭД ы│┤ыеШьЛЬэВдъ│а Transaction ьЧЖьЭ┤ ьЛдэЦЙ / TransactionьЭ┤ ьЧЖьЭД ъ▓╜ьЪ░ ъ╖╕ыГе ьЛдэЦЙ(Transaction эХДьЪФьЧЖьЭМ)
		2.6 NEVER : ьЭ┤ып╕ TransactionьЭ┤ ьб┤ьЮмэХа ъ▓╜ьЪ░ Exception ы░ЬьГЭ / TransactionьЭ┤ ьЧЖьЭД ъ▓╜ьЪ░ Transaction ьЧЖьЭ┤ ьЛдэЦЙ(Transaction эХДьЪФьЧЖьЭМ)
		2.7 NESTED : ьЭ┤ып╕ TransactionьЭ┤ ьб┤ьЮмэХа ъ▓╜ьЪ░ эХ┤ыЛ╣ ьдСь▓йыРЬ Transaction ьЛдэЦЙ / TransactionьЭ┤ ьЧЖьЭД ъ▓╜ьЪ░ ьГИыбЬьЪ┤ Transaction ьГЭьД▒
			-> ъ╕░ьб┤ эК╕ыЮЬьЮньЕШьЭ┤ ьзДэЦЙьдСьЭ┤ый┤ эК╣ьаХ ыйФьЖМыУЬъ░А ы░ШыУЬьЛЬ ьдСь▓й эК╕ыЮЬьЮньЕШ(nested transaction)ыВ┤ьЧРьДЬ ьЛдэЦЙыРШьЦ┤ьХ╝ эХиьЭД ьЭШып╕.
			   nested transactionьЭА enclosing transactionъ│╝ыКФ ы│Дъ░ЬыбЬ ь╗ды░ЛыРШъ▒░ыВШ ыбды░▒ыРа ьИШ ьЮИыЛд.
			   enclosing transactionьЭ┤ ьЧЖьЭД ъ▓╜ьЪ░ REQUIREDьЩА ыПЩьЭ╝эХШъ▓М ыПЩьЮСэХЬыЛд.

	3. ISOLATION
		3.1 DEFAULT : DatastoreьЭШ ъ╕░ы│╕ isolation level ьВмьЪй
		3.2 READ_UNCOMMITTED : ы│Аъ▓╜ьЭ┤ ьХДьзБ ь╗ды░ЛыРШьзА ьХКьЭА ыН░ьЭ┤эД░ьЧР ыМАэХЬ ьЭ╜ъ╕░ые╝ эЧИьЪйэХЬыЛд.(dirty read, phantom read, nonrepeatable read ы░ЬьГЭыРа ьИШ ьЮИыЛд.)
		3.3 READ_COMMITTED : ь╗ды░ЛыРЬ ыПЩьЛЬ эК╕ыЮЬьЮньЕШьЬ╝ыбЬы╢АэД░ ьЭ╜ъ╕░ые╝ эЧИьЪйэХЬыЛд.(dirty read ы░йьзА, phantom read, nonrepeatable read ы░ЬьГЭыРа ьИШ ьЮИыЛд.)
		3.4 REPEATABLE_READ : ьЮРьЛаьЭ┤ ыН░ьЭ┤эД░ые╝ ы│Аъ▓╜эХШьзА ьХКыКФ эХЬ, ыПЩьЭ╝эХЬ эХДыУЬьЧР ыМАэХЬ ьЧмыЯмы▓ИьЭШ ьЭ╜ъ╕░ъ░А ыПЩьЭ╝эХЬ ъ▓░ъ│╝ые╝ ьЦ╗ьЭД ьИШ ьЮИыПДыбЭ эХЬыЛд.(dirty read, nonrepeatable read ы░йьзА, phantom read ы░ЬьГЭыРа ьИШ ьЮИыЛд.)
		3.5 SERIALIZABLE : dirty read, phantom read, nonrepeatable read ыкиыСР ы░йьзАэХШыКФ ьЩДьаДэХЬ ACIDьЩА ы╢АэХйыРШыКФ ы╢Дыжм ыаИы▓иьЭ┤ыЛд.(эК╕ыЮЬьЮньЕШьЧР ъ┤АьЧмыРЬ эЕМьЭ┤ы╕ФыУдьЧР ыМАэХ┤ ьЩДьаДэХЬ эЕМьЭ┤ы╕Ф ьЮаъ╕ИьЭД ьИШэЦЙэХШъ╕░ ыХМым╕ьЧР ьД▒ыКеьЭ┤ ъ░АьЮеьвЛьзА ьХКыЛд.)
